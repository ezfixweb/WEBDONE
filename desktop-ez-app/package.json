{
  "name": "ezfix-windows-app",
  "version": "1.0.10",
  "description": "Desktop management app for EzFix orders and inventory",
  "main": "main.js",
  "author": "EzFix",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "dist:publish": "electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "cz.ezfix.desktop",
    "productName": "EzFix Manager",
    "win": {
      "icon": "assets/logos/app-icon.ico",
      "signAndEditExecutable": true,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EzFix Manager",
      "installerIcon": "assets/logos/app-icon.ico",
      "uninstallerIcon": "assets/logos/app-icon.ico",
      "installerHeaderIcon": "assets/logos/app-icon.ico",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": true,
      "uninstallDisplayName": "EzFix Manager"
    },
    "publish": {
      "provider": "github",
      "owner": "ezfixweb",
      "repo": "WEBDONE",
      "releaseType": "release"
    }
  }
}
